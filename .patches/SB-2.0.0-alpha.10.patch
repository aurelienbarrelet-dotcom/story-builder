diff --git a/style.css b/style.css
index 00ea217..56daaae 100644
--- a/style.css
+++ b/style.css
@@ -4196,3 +4196,58 @@ body:not(.reader-mode) .chapter.multi-selected .chapter-number {
     line-height: 1.5;
     text-align: center;
 }
+
+
+/* Alpha 10 — Images : espace de travail large en deux colonnes */
+main.assets-panel-open {
+    grid-template-columns: 260px minmax(300px, .72fr) minmax(640px, 1.28fr) !important;
+}
+
+main.assets-panel-open .right-panels-shell {
+    min-width: 640px;
+}
+
+main.assets-panel-open .assets-workspace {
+    grid-template-columns: minmax(0, 2fr) minmax(240px, 1fr);
+}
+
+main.assets-panel-open .assets-grid {
+    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
+    gap: 16px 12px;
+}
+
+main.assets-panel-open .asset-inspector {
+    min-width: 240px;
+}
+
+@media (max-width: 1450px) {
+    main.assets-panel-open {
+        grid-template-columns: 230px minmax(280px, .68fr) minmax(580px, 1.32fr) !important;
+    }
+
+    main.assets-panel-open .right-panels-shell {
+        min-width: 580px;
+    }
+
+    main.assets-panel-open .assets-workspace {
+        grid-template-columns: minmax(0, 1.8fr) minmax(220px, 1fr);
+    }
+}
+
+@media (max-width: 1100px) {
+    main.assets-panel-open {
+        grid-template-columns: 220px minmax(240px, .55fr) minmax(520px, 1.45fr) !important;
+    }
+
+    main.assets-panel-open .right-panels-shell {
+        min-width: 520px;
+    }
+
+    main.assets-panel-open .assets-workspace {
+        grid-template-columns: minmax(0, 1.55fr) minmax(200px, 1fr);
+    }
+
+    main.assets-panel-open .assets-grid {
+        grid-template-columns: repeat(auto-fill, minmax(118px, 1fr));
+    }
+}
