diff --git a/style.css b/style.css
index ecf71cb..1a85c14 100644
--- a/style.css
+++ b/style.css
@@ -5532,3 +5532,34 @@ body > .collection-menu { z-index: 1000; }
 .transition-panel-section .camera-form:last-child {
     margin-bottom: 0;
 }
+
+
+/* Alpha 28.2 — contrôle des transitions de calques */
+.transition-toggle-property {
+    padding-bottom: var(--space-6);
+    border-bottom: var(--border-width) solid var(--color-border);
+}
+
+.transition-toggle {
+    display: flex;
+    align-items: center;
+    gap: var(--space-4);
+    margin: 0;
+    cursor: pointer;
+}
+
+.transition-toggle input {
+    width: auto;
+    margin: 0;
+}
+
+.transition-toggle span {
+    font-weight: 700;
+}
+
+.transition-toggle-property .property-help {
+    margin: var(--space-3) 0 0 calc(16px + var(--space-4));
+    color: var(--color-text-muted);
+    font-size: 11px;
+    line-height: 1.45;
+}
