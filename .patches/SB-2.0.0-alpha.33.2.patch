+.transition-layer-remove:hover { background: #f8e9ec; }
+.transition-layer-editor { display: grid; gap: 12px; margin-top: 12px; padding-top: 12px; border-top: 1px solid #e5e7eb; }
+.transition-layer-selection-summary { margin: 0; color: #5b616b; font-size: 11px; }
