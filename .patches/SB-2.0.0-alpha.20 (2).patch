diff --git a/style.css b/style.css
index b35682d..8396746 100644
--- a/style.css
+++ b/style.css
@@ -4901,3 +4901,56 @@ body:not(.reader-mode) .chapter {
     outline: 0;
     box-shadow: var(--focus-ring);
 }
+
+
+/* Alpha 20 — finitions et accessibilité visuelle */
+:root {
+    --surface-subtle: #f7f8f9;
+    --surface-hover: #f1f3f5;
+}
+* {
+    scrollbar-width: thin;
+    scrollbar-color: #c7ccd1 transparent;
+}
+*::-webkit-scrollbar { width: 9px; height: 9px; }
+*::-webkit-scrollbar-thumb {
+    border: 2px solid transparent;
+    border-radius: 999px;
+    background: #c7ccd1;
+    background-clip: padding-box;
+}
+*::-webkit-scrollbar-thumb:hover { background-color: #aeb5bc; }
+.empty-state,
+.asset-inspector-empty,
+.panel-empty-state {
+    padding: 28px 18px;
+    color: var(--text-secondary);
+    text-align: center;
+}
+.empty-state svg,
+.asset-inspector-empty svg,
+.panel-empty-state svg {
+    opacity: .55;
+}
+.ui-button,
+.ui-icon-button,
+.button,
+.icon-button {
+    -webkit-tap-highlight-color: transparent;
+}
+.ui-button:hover:not(:disabled),
+.button:hover:not(:disabled) {
+    text-decoration: none;
+}
+:where(button, input, select, textarea, [tabindex]):focus-visible {
+    outline: 0;
+    box-shadow: var(--focus-ring);
+}
+@media (prefers-reduced-motion: reduce) {
+    *, *::before, *::after {
+        scroll-behavior: auto !important;
+        transition-duration: .01ms !important;
+        animation-duration: .01ms !important;
+        animation-iteration-count: 1 !important;
+    }
+}
