+
+
+/* Alpha 34.0 — consolidation UI des panneaux et du sélecteur commun */
+:where(.properties-panel-header, .layers-panel-header, .legend-panel-header) {
+    box-sizing: border-box;
+    min-height: 50px;
+    padding: var(--space-5) var(--space-6);
+    border-bottom: var(--border-width) solid var(--panel-divider);
+    background: var(--color-surface);
+}
+:where(.properties-panel-title, .layers-panel-title, .legend-panel-title) h2 {
+    margin: 0;
+    color: var(--text-primary);
+    font-size: var(--space-7);
+    line-height: 1.25;
+}
+:where(.legend-section-heading, .transition-panel-section-header) {
+    min-height: 32px;
+    padding-bottom: var(--space-3);
+    border-bottom: var(--border-width) solid var(--panel-divider);
+}
+:where(.legend-section-heading, .transition-panel-section-header) h3 {
+    margin: 0;
+    color: var(--text-primary);
+    font-size: 12px;
+    font-weight: 750;
+}
+:where(.legend-section-heading, .transition-panel-section-header) span {
+    color: var(--text-secondary);
+    font-size: 10px;
+}
+.panel-empty-state--compact {
+    box-sizing: border-box;
+    width: 100%;
+    margin: 0;
+    padding: var(--space-7) var(--space-5);
+    border: var(--border-width) dashed var(--ui-border);
+    border-radius: var(--ui-radius);
+    color: var(--ui-text-muted);
+    background: var(--surface-subtle);
+    font-size: var(--space-5);
+    line-height: 1.5;
+    text-align: center;
+}
+.legend-empty.panel-empty-state--compact { border-color: var(--ui-border); }
+.collection-add-button {
+    flex: 0 0 auto;
+    border-color: var(--ui-accent);
+    color: var(--color-white);
+    background: var(--ui-accent);
+}
+.collection-add-button:hover:not(:disabled) {
+    border-color: var(--ui-accent-hover);
+    background: var(--ui-accent-hover);
+}
+.layer-picker-dialog {
+    box-sizing: border-box;
+    gap: var(--space-5);
+    border-color: var(--ui-border);
+    border-radius: 12px;
+}
+.layer-picker-header p { max-width: 52ch; line-height: 1.45; }
+.layer-picker-list { border-color: var(--ui-border); border-radius: var(--ui-radius); }
+.layer-picker-row { transition: var(--ui-transition); }
+.layer-picker-row:has(input:checked:not(:disabled)) {
+    background: color-mix(in srgb, var(--ui-accent) 7%, var(--ui-surface));
+    box-shadow: inset 3px 0 0 var(--ui-accent);
+}
+.layer-picker-row:focus-within { box-shadow: inset 0 0 0 2px var(--ui-accent); }
+.layer-picker-footer {
+    padding-top: var(--space-4);
+    border-top: var(--border-width) solid var(--panel-divider);
+}
+.layer-picker-actions { display: flex; gap: var(--space-3); }
+.layer-picker-count { font-weight: 700; }
+@media (max-width: 700px) {
+    .layer-picker-backdrop { align-items: end; padding: 0; }
+    .layer-picker-dialog {
+        grid-template-rows: auto auto minmax(160px, 1fr) auto;
+        width: 100%;
+        max-height: 92dvh;
+        padding: var(--space-6);
+        border-right: 0;
+        border-bottom: 0;
+        border-left: 0;
+        border-radius: 14px 14px 0 0;
+    }
+    .layer-picker-row { grid-template-columns: auto 38px minmax(0, 1fr); }
+    .layer-picker-row em { grid-column: 3; }
+    .layer-picker-preview { width: 34px; height: 34px; }
+    .layer-picker-footer { align-items: stretch; flex-direction: column; }
+    .layer-picker-actions { display: grid; grid-template-columns: 1fr 1fr; }
+    .layer-picker-actions .button { width: 100%; min-height: 40px; }
+}
