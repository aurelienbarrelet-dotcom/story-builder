diff --git a/style.css b/style.css
index 804abc5..81f7546 100644
--- a/style.css
+++ b/style.css
@@ -5743,3 +5743,97 @@ body > .collection-menu { z-index: 1000; }
 .layer-picker-preview--symbol i { color: var(--layer-preview-color); font-size: 21px; font-weight: 800; line-height: 1; text-shadow: 0 1px 0 var(--layer-preview-secondary); }
 .layer-picker-preview--heatmap i, .layer-picker-preview--hillshade i, .layer-picker-preview--raster i { width: 28px; height: 24px; border-radius: 6px; background: radial-gradient(circle at 65% 35%, #fff 0 8%, transparent 9%), linear-gradient(135deg, var(--layer-preview-secondary), var(--layer-preview-color)); }
