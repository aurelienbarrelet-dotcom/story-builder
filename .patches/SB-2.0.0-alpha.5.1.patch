diff --git a/style.css b/style.css
index bfa5e66..9807c8e 100644
--- a/style.css
+++ b/style.css
@@ -3976,13 +3976,13 @@ body:not(.reader-mode) .chapter.multi-selected .chapter-number {
 
 /* Alpha 5 — Asset Manager */
 .assets-panel { min-width: 0; background: #fff; border-left: 1px solid #ddd; overflow: hidden; }
-.assets-panel-header { display: grid; grid-template-columns: 1fr auto; gap: 4px 12px; align-items: center; padding: 16px; border-bottom: 1px solid #e6e6e6; }
+.assets-panel-header { display: grid; gap: 10px; padding: 16px; border-bottom: 1px solid #e6e6e6; }
 .assets-panel-header h2 { margin: 0; font-size: 16px; }
-.assets-panel-header p { grid-column: 1; margin: 0; color: #777; font-size: 12px; }
-.assets-panel-header .button { grid-column: 2; grid-row: 1 / span 2; }
+.assets-panel-header .button { width: 100%; }
 .assets-panel-content { height: calc(100vh - 112px); overflow: auto; padding: 14px; }
 .assets-grid { display: grid; gap: 12px; }
-.asset-card { overflow: hidden; border: 1px solid #ddd; border-radius: 10px; background: #fff; }
+.asset-card { overflow: hidden; border: 1px solid #ddd; border-radius: 10px; background: #fff; transition: background .15s ease, border-color .15s ease, box-shadow .15s ease; }
+.asset-card.selected { background: var(--accent-soft); border-color: rgba(130, 11, 28, .35); box-shadow: 0 0 0 2px rgba(130, 11, 28, .14); }
 .asset-card > img { display: block; width: 100%; height: 130px; object-fit: cover; background: #f2f2f2; }
 .asset-card-body { display: grid; gap: 5px; padding: 10px; }
 .asset-card-body span { color: #777; font-size: 11px; }
