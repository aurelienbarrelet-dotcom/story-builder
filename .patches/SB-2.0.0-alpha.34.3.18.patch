diff --git a/js/features/models3d/models3d-map.js b/js/features/models3d/models3d-map.js
index 7e12fb0..7a66fac 100644
--- a/js/features/models3d/models3d-map.js
+++ b/js/features/models3d/models3d-map.js
@@ -92,6 +92,27 @@ export function snapSelectedInstanceToTerrain() {
 }
 
 
+export function deleteModelInstances(instanceIds) {
+    const ids = instanceIds instanceof Set ? instanceIds : new Set(instanceIds || []);
+    if (!ids.size) return 0;
+    const instances = getInstanceLibrary();
+    const initialCount = instances.length;
+    for (let index = instances.length - 1; index >= 0; index -= 1) {
+        if (ids.has(instances[index]?.id)) instances.splice(index, 1);
+    }
+    const deletedCount = initialCount - instances.length;
+    if (!deletedCount) return 0;
+    if (ids.has(selectedInstanceId)) {
+        selectedInstanceId = null;
+        setSelectedInstanceMoveMode(false);
+    }
+    emit(EVENTS.PROJECT_DIRTY_CHANGED, { isDirty: true });
+    saveProjectLocally();
+    emit(EVENTS.MODEL3D_INSTANCE_SELECTED, { instanceId: selectedInstanceId, moveModeActive });
+    renderModelInstances();
+    return deletedCount;
+}
+
 export function deleteSelectedModelInstance() {
     const instances = getInstanceLibrary();
     const index = instances.findIndex(item => item.id === selectedInstanceId);
diff --git a/style.css b/style.css
index c216f64..eb14edf 100644
--- a/style.css
+++ b/style.css
@@ -6045,3 +6045,116 @@ main.models3d-panel-open .right-panels-shell {
         grid-template-columns: minmax(190px, .8fr) minmax(0, 1.2fr);
     }
 }
+
+/* Alpha 34.3.18 — sélection multiple et harmonisation du panneau Objets 3D */
+.models3d-object-browser-pane {
+    min-width: 0;
+    min-height: 0;
+    display: flex;
+    flex-direction: column;
+    overflow: hidden;
+    background: var(--right-panel-bg);
+}
+
+.models3d-object-list {
+    flex: 1;
+    min-height: 0;
+}
+
+.models3d-selection-bar {
+    flex: 0 0 auto;
+    margin: 0 var(--right-panel-padding) var(--right-panel-padding);
+}
+
+.models3d-object-row {
+    position: relative;
+    min-height: 48px;
+    border-color: transparent;
+    border-radius: var(--space-3);
+    background: var(--color-surface);
+    color: var(--text-primary);
+    font: inherit;
+    transition: background-color var(--duration-standard) ease, border-color var(--duration-standard) ease, box-shadow var(--duration-standard) ease;
+}
+
+.models3d-object-row:hover {
+    border-color: var(--panel-border);
+    background: var(--color-surface-soft);
+}
+
+.models3d-object-row.multi-selected,
+.models3d-object-row.is-selected {
+    border-color: var(--accent);
+    background: color-mix(in srgb, var(--accent) 9%, var(--color-surface));
+    box-shadow: inset 3px 0 0 var(--accent);
+}
+
+.models3d-object-row.is-selected {
+    box-shadow: inset 3px 0 0 var(--accent), 0 0 0 1px var(--accent-ring);
+}
+
+.models3d-object-status {
+    width: 8px;
+    height: 8px;
+    overflow: hidden;
+    border-radius: 50%;
+    color: transparent;
+    background: var(--accent);
+}
+
+.models3d-object-name {
+    font-size: 13px;
+    font-weight: 650;
+    line-height: 1.35;
+}
+
+.models3d-object-inspector {
+    color: var(--text-primary);
+}
+
+.models3d-instance-card {
+    padding: 0;
+    border: 0;
+    border-radius: 0;
+    background: transparent;
+}
+
+.models3d-instance-card > h3 {
+    margin: 0 0 var(--space-1);
+    font-size: 16px;
+    font-weight: 700;
+    line-height: 1.3;
+}
+
+.models3d-instance-card > p {
+    margin-bottom: var(--space-5);
+    color: var(--text-secondary);
+    font-size: 12px;
+}
+
+.models3d-instance-card > .ui-button {
+    min-height: 36px;
+    border-radius: var(--control-radius);
+    font-size: 12px;
+    font-weight: 650;
+}
+
+.models3d-transform-editor {
+    margin-top: var(--space-5);
+    padding: var(--space-4);
+    border-color: var(--panel-border);
+    border-radius: var(--space-3);
+    background: var(--color-surface);
+}
+
+.models3d-transform-editor legend {
+    color: var(--text-primary);
+    font-size: 12px;
+    font-weight: 700;
+}
+
+.models3d-transform-field,
+.models3d-terrain-follow {
+    color: var(--text-secondary);
+    font-family: inherit;
+}
