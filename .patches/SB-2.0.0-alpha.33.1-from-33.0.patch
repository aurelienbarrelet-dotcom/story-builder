+.transition-timeline-ruler { left: 82px; }
+.transition-timeline-track { grid-template-columns: 72px minmax(0, 1fr); min-width: 0; }
+.transition-timeline-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.transition-timeline-playhead { left: 82px; }
+.selected-layer-transition-section { min-width: 0; }
+.transition-sequence-row { display: grid; grid-template-columns: minmax(0, 1fr) 76px auto; align-items: end; gap: var(--space-3); }
+.transition-sequence-row label { color: var(--text-secondary); font-size: 11px; font-weight: 700; }
+.transition-sequence-row input { width: 100%; min-width: 0; }
+.transition-sequence-row .button { min-height: var(--field-height); padding-inline: var(--space-4); }
+@media (max-width: 900px) {
+    .transition-sequence-row { grid-template-columns: 1fr 80px; }
+    .transition-sequence-row .button { grid-column: 1 / -1; }
+}
