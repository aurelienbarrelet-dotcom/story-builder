diff --git a/style.css b/style.css
index f33d123d02c1d49c9c41a7b623dbfdfa273b1e10..a360781628c4e96b03674d25d1b938a76db79fd2 100644
--- a/style.css
+++ b/style.css
@@ -5244,3 +5244,59 @@ body:not(.reader-mode) .chapter:hover {
 .collection-selection-bar[hidden] {
     display: none !important;
 }
+
+/* SB-2.0.0-alpha.23 — Legends as collections */
+.legend-panel-content { gap: 12px; }
+.legend-section.collection-panel { min-height: 0; }
+.legend-section-heading.collection-panel-header {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: 10px;
+}
+.legend-section-heading.collection-panel-header > div { min-width: 0; }
+.legend-available-list,
+.legend-current-list {
+    display: flex;
+    flex-direction: column;
+    align-items: stretch;
+    gap: 6px;
+    min-height: 0;
+}
+.legend-available-row,
+.legend-item-card {
+    flex: 0 0 auto;
+    min-height: 52px;
+    display: grid;
+    grid-template-columns: auto auto minmax(0, 1fr) auto;
+    align-items: center;
+    gap: 8px;
+    padding: 8px;
+    border: 1px solid var(--collection-card-border, #d9dee8);
+    border-radius: 8px;
+    background: var(--collection-card-background, #fff);
+    cursor: pointer;
+    transition: border-color 140ms ease, background-color 140ms ease;
+}
+.legend-available-row:hover,
+.legend-item-card:hover { background: var(--collection-card-hover, #f7f9fc); }
+.legend-available-row.selected,
+.legend-item-card.selected {
+    border-color: var(--accent-color, #df2f3b);
+    box-shadow: 0 0 0 1px var(--accent-color, #df2f3b);
+}
+.legend-available-row.is-added { opacity: .55; cursor: default; }
+.legend-item-copy,
+.legend-available-copy { min-width: 0; display: grid; gap: 2px; }
+.legend-item-copy strong,
+.legend-item-copy small,
+.legend-available-copy strong,
+.legend-available-copy small { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.legend-item-copy strong,
+.legend-available-copy strong { font-size: 12px; }
+.legend-item-copy small,
+.legend-available-copy small { color: #7b838c; font-size: 10px; }
+.legend-item-card .collection-card-actions { position: relative; }
+.legend-selection-bar { margin-top: 6px; }
+.legend-add-selected,
+.legend-icon-button { display: none !important; }
